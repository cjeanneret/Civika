# Backend
API_HOST=0.0.0.0
API_PORT=8080
API_READ_TIMEOUT=10s
API_WRITE_TIMEOUT=10s
API_IDLE_TIMEOUT=30s
API_BODY_MAX_BYTES=1048576
API_QA_RATE_LIMIT_QPS=1
API_QA_RATE_LIMIT_BURST=3
API_QA_RATE_LIMIT_CLEANUP_INTERVAL=1m
DEBUG_LOG_ENABLED=false
DEBUG_LOG_PATH=/tmp/debug-2055fd.log

# LLM configuration
LLM_ENABLED=false
LLM_BASE_URL=https://example-llm.local
LLM_API_KEY=replace-me
LLM_MODEL_NAME=model-placeholder
LLM_TIMEOUT=10s
LLM_TRANSLATION_TIMEOUT=120s
LLM_TRANSLATION_MAX_RETRIES=2
LLM_MAX_PROMPT_CHARS=4000
LLM_MAX_OUTPUT_TOKENS_SUMMARIZATION=220
LLM_MAX_OUTPUT_TOKENS_TRANSLATION=800

# LLM embedding configuration (RAG)
LLM_EMBEDDING_ENABLED=false
LLM_EMBEDDING_BASE_URL=https://example-llm.local
LLM_EMBEDDING_API_KEY=replace-me
LLM_EMBEDDING_MODEL_NAME=embedding-model-placeholder
LLM_EMBEDDING_TIMEOUT=10s
LLM_EMBEDDING_MAX_INPUT_CHARS=4000

# PostgreSQL + pgvector
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-me
POSTGRES_DB=civika
POSTGRES_SSLMODE=disable
POSTGRES_MAX_OPEN_CONNS=10
POSTGRES_MAX_IDLE_CONNS=5

# RAG parameters
RAG_MODE=local
RAG_INDEX_TIMEOUT=0
RAG_TOP_K=5
RAG_CHUNK_SIZE_TOKENS=768
RAG_CHUNK_OVERLAP_RATIO=0.15
RAG_TABLE_NAME=rag_chunks
RAG_EMBEDDING_DIMENSIONS=128
RAG_SUPPORTED_LANGUAGES=fr,de,it,rm,en
RAG_DEFAULT_LANGUAGE=fr
RAG_FALLBACK_LANGUAGE=en

# Data fetch (incremental cache)
DATA_FETCH_VOTINGS_LIMIT=5
DATA_FETCH_MAX_DEPTH=3
DATA_FETCH_MAX_NODES_PER_VOTING=150
DATA_FETCH_MIN_REQUEST_INTERVAL=1s
DATA_FETCH_MAX_RETRIES=3
DATA_FETCH_BACKOFF_MAX=30s
DATA_FETCH_CACHE_DIR=data/fetch-cache/openparldata
DATA_FETCH_CACHE_TTL=72h
DATA_FETCH_CACHE_RETENTION=168h
DATA_FETCH_FORCE_REFRESH=false

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
INTERNAL_API_BASE_URL=http://localhost:8080
